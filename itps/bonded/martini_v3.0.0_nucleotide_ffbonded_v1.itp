;;;;;;;;;;;;;;;;;
;;; NAD(P)(H) ;;;
;;;;;;;;;;;;;;;;;

;;; NOTE: P4 is the phosphate ion bead attached to the 2' carbon of the ribose carrying the adenine.
;;; it is NOT called P3 as this may be confused with the terminal P3 bead of triphosphates

[ bondtypes ]
#define b_ARO1_ARO2 1 0.206 10000  
#define b_ARO1_AMD1 1 0.428 10000 
#define b_ARO2_AMD1 1 0.411 10000 
#define b_ARO1_CAC1 1 0.391 10000
#define b_ARO2_CAC1 1 0.410 10000

#define b_RIB1_P4   1 0.314 10000
#define b_RIB7_ARO1 1 0.260 10000

[ constrainttypes ]
#define c_ARO1_ARO2 1 0.206
#define c_ARO1_AMD1 1 0.428  
#define c_ARO2_AMD1 1 0.411  
#define c_ARO1_CAC1 1 0.391
#define c_ARO2_CAC1 1 0.410

#define c_RIB1_P4   1 0.314 
#define c_RIB7_ARO1 1 0.260

[ angletypes ]
#define a_RIB5_RIB7_ARO1  10  87.967 100
#define a_RIB7_ARO1_AMD1  10 128.396  81.634
#define a_RIB7_ARO1_CAC1  10 110      67.626
#define a_ADE1_RIB1_P4    10 126.063  76.734

[ dihedraltypes ]
#define d_P2_RIB5_RIB7_ARO1    2 -79.527 91.882
#define d_RIB5_RIB7_ARO1_AMD1  2  83.079 40
#define d_RIB5_RIB7_ARO1_CAC1  2  85.657 40
#define d_P1_P2_RIB5_RIB7      1 158.858 -2.497 1
#define d_RIB3_P1_P2_RIB5      2 -16.1    6.494 

















