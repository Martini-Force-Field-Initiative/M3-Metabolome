;;;; notes
; x_D_... indicates an interaction for a deoxyribose
; x_H_... indicates an interaction for a protonated form

;;;;;;;;;;;;;;
;;; sugars ;;;
;;;;;;;;;;;;;;

[ bondtypes ]
; oxyribose
#define b_RIB1_RIB2 1 0.235 10000   ; needs to be a constraint also
#define b_RIB1_RIB3 1 0.334 10000   ; changed from 0.345 needs to be a constraint also
#define b_RIB2_RIB3 1 0.290 10000   ; needs to be a constraint also
; deoxyribose
#define b_D_RIB1_RIB2  1 0.234 10000 ; needs to be a constraint also
#define b_D_RIB1_RIB3  1 0.313 10000 ; changed from 0.330 needs to be a constraint also
#define b_D_RIB2_RIB3  1 0.287 10000 ; needs to be a constraint also

[ constrainttypes ]
; oxyribose
#define c_RIB1_RIB2 1 0.235 
#define c_RIB1_RIB3 1 0.334
#define c_RIB2_RIB3 1 0.290   
; deoxyribose
#define c_D_RIB1_RIB2  1 0.234
#define c_D_RIB1_RIB3  1 0.313
#define c_D_RIB2_RIB3  1 0.287

;;;;;;;;;;;;;;;;;;;;;;;
;;; phosphate stuff ;;;
;;;;;;;;;;;;;;;;;;;;;;;

[ bondtypes ]
#define b_RIB3_P1 1 0.330 10000 ; needs to be a constraint also
#define b_P1_P2   1 0.263 10000 ; needs to be a constraint also
#define b_P2_P3   1 0.263 10000 ; needs to be a constraint also

#define b_H_P1_P2 1 0.284 10000 ; needs to be a constraint also, iff P2 is terminal
#define b_H_P2_P3 1 0.284 10000 ; needs to be a constraint also, iff P3 is terminal


[ constrainttypes ]
#define c_RIB3_P1 1 0.330
#define c_P1_P2   1 0.263 
#define c_P2_P3   1 0.263 

#define c_H_P1_P2 1 0.284 
#define c_H_P2_P3 1 0.284 

[ angletypes ]
;n.b. D, H types are close enough to be the same
#define a_RIB1_RIB3_P1 10 105  23 
#define a_RIB3_P1_P2   10 116  90 
#define a_P1_P2_P3      1 158 750 

[ dihedraltypes ]
;n.b. D, H types are close enough to be the same
#define d_RIB1_RIB3_P1_P2 1   110 -4.0 1 
#define d_RIB3_P1_P2_P3   2   0.0  5.0 


;;;;;;;;;;;;;;;;;
;;; Adenosine ;;;
;;;;;;;;;;;;;;;;;

[ bondtypes ]
#define b_ADE1_RIB1   1 0.273 9700 
#define b_D_ADE1_RIB1 1 0.245 10000 ; needs to be a constraint also

[ constrainttypes ]
#define c_D_ADE1_RIB1 1 0.245 

[ angletypes ]
#define a_ADE2_ADE1_RIB1 10  75  40 

#define a_ADE1_RIB1_RIB2 10 135 105 
#define a_ADE1_RIB1_RIB3 10  80  40 
#define a_D_ADE1_RIB1_RIB2 10 150 100 
#define a_D_ADE1_RIB1_RIB3 10  90 100 

[ dihedraltypes ]
; ring
#define d_ADE1_ADE2_ADE5_ADE4 2 180.0 400

; adenine-sugar link
#define d_ADE2_ADE1_RIB1_RIB3_1 9   36  2.4 1
#define d_ADE2_ADE1_RIB1_RIB3_2 9   97 -2.5 2
#define d_ADE2_ADE1_RIB1_RIB3_3 9  -90 -0.9 3
#define d_ADE2_ADE1_RIB1_RIB3_4 9 -156 -0.6 4
#define d_ADE2_ADE1_RIB1_RIB3_5 9  -25 -0.5 5

#define d_ADE1_RIB1_RIB2_RIB3 2 0 10

; adenine-sugar-phosphate
#define d_ADE1_RIB1_RIB3_P1 2 -110 5


